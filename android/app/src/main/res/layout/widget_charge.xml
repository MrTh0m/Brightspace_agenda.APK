<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Charge par semaine"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="6dp" />

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        android:layout_marginBottom="2dp" />

    <!-- Semaine 1 -->
    <LinearLayout android:id="@+id/widget_charge_row_1"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal"
        android:gravity="center_vertical" android:visibility="gone">
        <TextView android:id="@+id/widget_charge_week_1"
            android:layout_width="60dp" android:layout_height="wrap_content"
            android:textSize="9sp" android:textColor="#99FFFFFF" />
        <ProgressBar android:id="@+id/widget_charge_bar_1"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp" android:layout_height="8dp"
            android:layout_weight="1" android:max="100"
            android:progress="0" android:secondaryProgress="0"
            android:progressTint="#52C77A"
            android:secondaryProgressTint="#CC3333"
            android:progressBackgroundTint="#22FFFFFF" />
        <TextView android:id="@+id/widget_charge_count_1"
            android:layout_width="24dp" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#FFFFFF"
            android:gravity="end" android:textStyle="bold" />
    </LinearLayout>

    <!-- Semaine 2 -->
    <LinearLayout android:id="@+id/widget_charge_row_2"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal"
        android:gravity="center_vertical" android:visibility="gone">
        <TextView android:id="@+id/widget_charge_week_2"
            android:layout_width="60dp" android:layout_height="wrap_content"
            android:textSize="9sp" android:textColor="#99FFFFFF" />
        <ProgressBar android:id="@+id/widget_charge_bar_2"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp" android:layout_height="8dp"
            android:layout_weight="1" android:max="100"
            android:progress="0" android:secondaryProgress="0"
            android:progressTint="#52C77A"
            android:secondaryProgressTint="#CC3333"
            android:progressBackgroundTint="#22FFFFFF" />
        <TextView android:id="@+id/widget_charge_count_2"
            android:layout_width="24dp" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#FFFFFF"
            android:gravity="end" android:textStyle="bold" />
    </LinearLayout>

    <!-- Semaine 3 -->
    <LinearLayout android:id="@+id/widget_charge_row_3"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal"
        android:gravity="center_vertical" android:visibility="gone">
        <TextView android:id="@+id/widget_charge_week_3"
            android:layout_width="60dp" android:layout_height="wrap_content"
            android:textSize="9sp" android:textColor="#99FFFFFF" />
        <ProgressBar android:id="@+id/widget_charge_bar_3"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp" android:layout_height="8dp"
            android:layout_weight="1" android:max="100"
            android:progress="0" android:secondaryProgress="0"
            android:progressTint="#52C77A"
            android:secondaryProgressTint="#CC3333"
            android:progressBackgroundTint="#22FFFFFF" />
        <TextView android:id="@+id/widget_charge_count_3"
            android:layout_width="24dp" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#FFFFFF"
            android:gravity="end" android:textStyle="bold" />
    </LinearLayout>

    <!-- Semaine 4 -->
    <LinearLayout android:id="@+id/widget_charge_row_4"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal"
        android:gravity="center_vertical" android:visibility="gone">
        <TextView android:id="@+id/widget_charge_week_4"
            android:layout_width="60dp" android:layout_height="wrap_content"
            android:textSize="9sp" android:textColor="#99FFFFFF" />
        <ProgressBar android:id="@+id/widget_charge_bar_4"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp" android:layout_height="8dp"
            android:layout_weight="1" android:max="100"
            android:progress="0" android:secondaryProgress="0"
            android:progressTint="#52C77A"
            android:secondaryProgressTint="#CC3333"
            android:progressBackgroundTint="#22FFFFFF" />
        <TextView android:id="@+id/widget_charge_count_4"
            android:layout_width="24dp" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#FFFFFF"
            android:gravity="end" android:textStyle="bold" />
    </LinearLayout>

    <!-- Semaine 5 -->
    <LinearLayout android:id="@+id/widget_charge_row_5"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal"
        android:gravity="center_vertical" android:visibility="gone">
        <TextView android:id="@+id/widget_charge_week_5"
            android:layout_width="60dp" android:layout_height="wrap_content"
            android:textSize="9sp" android:textColor="#99FFFFFF" />
        <ProgressBar android:id="@+id/widget_charge_bar_5"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp" android:layout_height="8dp"
            android:layout_weight="1" android:max="100"
            android:progress="0" android:secondaryProgress="0"
            android:progressTint="#52C77A"
            android:secondaryProgressTint="#CC3333"
            android:progressBackgroundTint="#22FFFFFF" />
        <TextView android:id="@+id/widget_charge_count_5"
            android:layout_width="24dp" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#FFFFFF"
            android:gravity="end" android:textStyle="bold" />
    </LinearLayout>

    <!-- Légende -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="2dp">
        <ImageView android:layout_width="8dp" android:layout_height="8dp"
            android:background="#52C77A" android:layout_marginEnd="4dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Rendus" android:textSize="9sp" android:textColor="#88FFFFFF"
            android:layout_marginEnd="12dp" />
        <ImageView android:layout_width="8dp" android:layout_height="8dp"
            android:background="#CC3333" android:layout_marginEnd="4dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="À rendre" android:textSize="9sp" android:textColor="#88FFFFFF" />
    </LinearLayout>

</LinearLayout>
