<?xml version="1.0" encoding="utf-8"?>
<!-- widget_agenda.xml — Agenda du jour (3×1)
     Par événement : dot couleur | heure début–fin | titre | code | intervenant
     Spacer en bas, nombre de lignes adaptatif selon hauteur widget -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="@drawable/widget_background">

    <!-- En-tête -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="3dp">
        <TextView android:id="@+id/widget_date"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="11sp" android:textStyle="bold"
            android:textColor="#FFFFFF" />
        <TextView android:id="@+id/widget_event_count"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#88FFFFFF" />
    </LinearLayout>

    <ImageView android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#33FFFFFF" android:layout_marginBottom="2dp" />

    <!-- Événement 1 -->
    <LinearLayout android:id="@+id/widget_row_1"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:visibility="gone">
        <ImageView android:id="@+id/widget_row_1_dot"
            android:layout_width="5dp" android:layout_height="5dp"
            android:layout_marginEnd="5dp" android:src="@drawable/widget_dot" android:scaleType="fitXY" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/widget_row_1_time"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="9sp" android:textColor="#88FFFFFF"
                    android:layout_marginEnd="4dp" />
                <TextView android:id="@+id/widget_row_1_title"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="11sp" android:textColor="#EEEEFF"
                    android:maxLines="1" android:ellipsize="end" android:textStyle="bold" />
            </LinearLayout>
            <TextView android:id="@+id/widget_row_1_detail"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="9sp" android:textColor="#88FFFFFF"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Événement 2 -->
    <LinearLayout android:id="@+id/widget_row_2"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:visibility="gone">
        <ImageView android:id="@+id/widget_row_2_dot"
            android:layout_width="5dp" android:layout_height="5dp"
            android:layout_marginEnd="5dp" android:src="@drawable/widget_dot" android:scaleType="fitXY" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/widget_row_2_time"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="9sp" android:textColor="#88FFFFFF"
                    android:layout_marginEnd="4dp" />
                <TextView android:id="@+id/widget_row_2_title"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="11sp" android:textColor="#EEEEFF"
                    android:maxLines="1" android:ellipsize="end" android:textStyle="bold" />
            </LinearLayout>
            <TextView android:id="@+id/widget_row_2_detail"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="9sp" android:textColor="#88FFFFFF"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Événement 3 -->
    <LinearLayout android:id="@+id/widget_row_3"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:visibility="gone">
        <ImageView android:id="@+id/widget_row_3_dot"
            android:layout_width="5dp" android:layout_height="5dp"
            android:layout_marginEnd="5dp" android:src="@drawable/widget_dot" android:scaleType="fitXY" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/widget_row_3_time"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="9sp" android:textColor="#88FFFFFF"
                    android:layout_marginEnd="4dp" />
                <TextView android:id="@+id/widget_row_3_title"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="11sp" android:textColor="#EEEEFF"
                    android:maxLines="1" android:ellipsize="end" android:textStyle="bold" />
            </LinearLayout>
            <TextView android:id="@+id/widget_row_3_detail"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="9sp" android:textColor="#88FFFFFF"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Événement 4 -->
    <LinearLayout android:id="@+id/widget_row_4"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:visibility="gone">
        <ImageView android:id="@+id/widget_row_4_dot"
            android:layout_width="5dp" android:layout_height="5dp"
            android:layout_marginEnd="5dp" android:src="@drawable/widget_dot" android:scaleType="fitXY" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/widget_row_4_time"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="9sp" android:textColor="#88FFFFFF"
                    android:layout_marginEnd="4dp" />
                <TextView android:id="@+id/widget_row_4_title"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="11sp" android:textColor="#EEEEFF"
                    android:maxLines="1" android:ellipsize="end" android:textStyle="bold" />
            </LinearLayout>
            <TextView android:id="@+id/widget_row_4_detail"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="9sp" android:textColor="#88FFFFFF"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Événement 5 -->
    <LinearLayout android:id="@+id/widget_row_5"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:visibility="gone">
        <ImageView android:id="@+id/widget_row_5_dot"
            android:layout_width="5dp" android:layout_height="5dp"
            android:layout_marginEnd="5dp" android:src="@drawable/widget_dot" android:scaleType="fitXY" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/widget_row_5_time"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="9sp" android:textColor="#88FFFFFF"
                    android:layout_marginEnd="4dp" />
                <TextView android:id="@+id/widget_row_5_title"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="11sp" android:textColor="#EEEEFF"
                    android:maxLines="1" android:ellipsize="end" android:textStyle="bold" />
            </LinearLayout>
            <TextView android:id="@+id/widget_row_5_detail"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="9sp" android:textColor="#88FFFFFF"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Vide -->
    <TextView android:id="@+id/widget_empty"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Aucun événement aujourd\'hui"
        android:textSize="11sp" android:textColor="#66FFFFFF"
        android:gravity="center" android:visibility="gone" />

    <!-- Spacer -->
    <TextView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:text="" />

</LinearLayout>
