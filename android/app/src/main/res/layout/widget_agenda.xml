<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- En-tête avec date -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/widget_event_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#99FFFFFF" />

    </LinearLayout>

    <!-- Séparateur -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="4dp"
        android:background="#33FFFFFF" />

    <!-- Ligne événement 1 -->
    <LinearLayout android:id="@+id/widget_row_1"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal"
        android:gravity="center_vertical" android:visibility="gone">
        <TextView android:id="@+id/widget_row_1_time"
            android:layout_width="36dp" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#99FFFFFF" />
        <View android:id="@+id/widget_row_1_dot"
            android:layout_width="5dp" android:layout_height="5dp"
            android:layout_marginEnd="6dp" android:background="@drawable/widget_dot" />
        <TextView android:id="@+id/widget_row_1_title"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="11sp" android:textColor="#FFFFFF"
            android:maxLines="1" android:ellipsize="end" />
    </LinearLayout>

    <!-- Ligne événement 2 -->
    <LinearLayout android:id="@+id/widget_row_2"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal"
        android:gravity="center_vertical" android:visibility="gone">
        <TextView android:id="@+id/widget_row_2_time"
            android:layout_width="36dp" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#99FFFFFF" />
        <View android:id="@+id/widget_row_2_dot"
            android:layout_width="5dp" android:layout_height="5dp"
            android:layout_marginEnd="6dp" android:background="@drawable/widget_dot" />
        <TextView android:id="@+id/widget_row_2_title"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="11sp" android:textColor="#FFFFFF"
            android:maxLines="1" android:ellipsize="end" />
    </LinearLayout>

    <!-- Ligne événement 3 -->
    <LinearLayout android:id="@+id/widget_row_3"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal"
        android:gravity="center_vertical" android:visibility="gone">
        <TextView android:id="@+id/widget_row_3_time"
            android:layout_width="36dp" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#99FFFFFF" />
        <View android:id="@+id/widget_row_3_dot"
            android:layout_width="5dp" android:layout_height="5dp"
            android:layout_marginEnd="6dp" android:background="@drawable/widget_dot" />
        <TextView android:id="@+id/widget_row_3_title"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="11sp" android:textColor="#FFFFFF"
            android:maxLines="1" android:ellipsize="end" />
    </LinearLayout>

    <!-- Ligne événement 4 -->
    <LinearLayout android:id="@+id/widget_row_4"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal"
        android:gravity="center_vertical" android:visibility="gone">
        <TextView android:id="@+id/widget_row_4_time"
            android:layout_width="36dp" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#99FFFFFF" />
        <View android:id="@+id/widget_row_4_dot"
            android:layout_width="5dp" android:layout_height="5dp"
            android:layout_marginEnd="6dp" android:background="@drawable/widget_dot" />
        <TextView android:id="@+id/widget_row_4_title"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="11sp" android:textColor="#FFFFFF"
            android:maxLines="1" android:ellipsize="end" />
    </LinearLayout>

    <!-- Ligne événement 5 -->
    <LinearLayout android:id="@+id/widget_row_5"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal"
        android:gravity="center_vertical" android:visibility="gone">
        <TextView android:id="@+id/widget_row_5_time"
            android:layout_width="36dp" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#99FFFFFF" />
        <View android:id="@+id/widget_row_5_dot"
            android:layout_width="5dp" android:layout_height="5dp"
            android:layout_marginEnd="6dp" android:background="@drawable/widget_dot" />
        <TextView android:id="@+id/widget_row_5_title"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="11sp" android:textColor="#FFFFFF"
            android:maxLines="1" android:ellipsize="end" />
    </LinearLayout>

    <!-- Message vide -->
    <TextView
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Aucun événement aujourd'hui"
        android:textSize="11sp"
        android:textColor="#66FFFFFF"
        android:gravity="center"
        android:visibility="gone" />

</LinearLayout>
