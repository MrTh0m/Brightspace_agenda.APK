            <TextView android:id="@+id/widget_ev_time_2_1" android:layout_width="32dp" android:layout_height="wrap_content"
                android:textSize="9sp" android:textColor="#88FFFFFF" />
            <TextView android:id="@+id/widget_ev_title_2_1" android:layout_width="0dp" android:layout_height="wrap_content"
