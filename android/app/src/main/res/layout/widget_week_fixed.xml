<?xml version="1.0" encoding="utf-8"?>
<!-- Layout commun week_fixed et week_sliding
     5 blocs jour (header + 3 lignes événement)
     Jours vides masqués — Kotlin remplit les blocs avec les jours ayant des événements
     Inspiré de renderGroupWeekList() : dot couleur | heure | titre -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="@drawable/widget_background">

    <!-- En-tête -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="3dp">
        <TextView android:id="@+id/widget_week_title"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="11sp" android:textStyle="bold"
            android:textColor="#FFFFFF" android:text="Semaine" />
        <TextView android:id="@+id/widget_week_label"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#88FFFFFF" />
    </LinearLayout>

    <ImageView android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#33FFFFFF" android:layout_marginBottom="2dp" />

    <!-- ── BLOC JOUR 1 ── -->
    <LinearLayout android:id="@+id/widget_block_1"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:visibility="gone"
        android:layout_marginBottom="4dp">
        <!-- Header jour -->
        <TextView android:id="@+id/widget_day_header_1"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="10sp" android:textStyle="bold" android:textColor="#FFFFFF"
            android:layout_marginBottom="1dp" />
        <!-- Événement 1a -->
        <LinearLayout android:id="@+id/widget_ev_1_1"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:visibility="gone">
            <ImageView android:id="@+id/widget_ev_dot_1_1"
                android:layout_width="5dp" android:layout_height="5dp"
                android:layout_marginEnd="5dp" android:src="@drawable/widget_dot" android:scaleType="fitXY" />
            <TextView android:id="@+id/widget_ev_time_1_1"
                android:layout_width="32dp" android:layout_height="wrap_content"
                android:textSize="9sp" android:textColor="#88FFFFFF" />
            <TextView android:id="@+id/widget_ev_title_1_1"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="10sp" android:textColor="#EEEEFF"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>
        <!-- Événement 1b -->
        <LinearLayout android:id="@+id/widget_ev_1_2"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:visibility="gone">
            <ImageView android:id="@+id/widget_ev_dot_1_2"
                android:layout_width="5dp" android:layout_height="5dp"
                android:layout_marginEnd="5dp" android:src="@drawable/widget_dot" android:scaleType="fitXY" />
            <TextView android:id="@+id/widget_ev_time_1_2"
                android:layout_width="32dp" android:layout_height="wrap_content"
                android:textSize="9sp" android:textColor="#88FFFFFF" />
            <TextView android:id="@+id/widget_ev_title_1_2"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="10sp" android:textColor="#EEEEFF"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>
        <!-- Événement 1c -->
        <LinearLayout android:id="@+id/widget_ev_1_3"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:visibility="gone">
            <ImageView android:id="@+id/widget_ev_dot_1_3"
                android:layout_width="5dp" android:layout_height="5dp"
                android:layout_marginEnd="5dp" android:src="@drawable/widget_dot" android:scaleType="fitXY" />
            <TextView android:id="@+id/widget_ev_time_1_3"
                android:layout_width="32dp" android:layout_height="wrap_content"
                android:textSize="9sp" android:textColor="#88FFFFFF" />
            <TextView android:id="@+id/widget_ev_title_1_3"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="10sp" android:textColor="#EEEEFF"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── BLOC JOUR 2 ── -->
