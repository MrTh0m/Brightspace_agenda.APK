            <ImageView android:id="@+id/widget_ev_dot_2_3" android:layout_width="5dp" android:layout_height="5dp"
                android:layout_marginEnd="5dp" android:src="@drawable/widget_dot" android:scaleType="fitXY" />
            <TextView android:id="@+id/widget_ev_time_2_3" android:layout_width="32dp" android:layout_height="wrap_content"
                android:textSize="9sp" android:textColor="#88FFFFFF" />
            <TextView android:id="@+id/widget_ev_title_2_3" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="10sp" android:textColor="#EEEEFF"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>
