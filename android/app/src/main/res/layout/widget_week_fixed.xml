                android:layout_weight="1" android:textSize="10sp" android:textColor="#EEEEFF"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>
        <LinearLayout android:id="@+id/widget_ev_4_2"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:visibility="gone">
            <ImageView android:id="@+id/widget_ev_dot_4_2" android:layout_width="5dp" android:layout_height="5dp"
