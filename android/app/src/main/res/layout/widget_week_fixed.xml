    <LinearLayout android:id="@+id/widget_block_4"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:visibility="gone"
        android:layout_marginBottom="4dp">
        <TextView android:id="@+id/widget_day_header_4"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="10sp" android:textStyle="bold" android:textColor="#FFFFFF"
