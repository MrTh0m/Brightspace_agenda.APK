# ── Secrets — JAMAIS dans Git ───────────────────────────────────────
# Le keystore signe l'app : s'il fuite, n'importe qui peut publier des
# mises à jour de cette app à ta place. S'il est perdu, impossible de
# publier une mise à jour de la même app — garde une sauvegarde HORS Git.
*.jks
*.keystore
key.properties

# ── Dépendances Node ─────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build Android / Gradle (reconstructible via npx cap sync) ────────
android/app/build/
android/build/
android/.gradle/
android/captures/
android/local.properties
android/.idea/
android/*.iml
android/app/*.iml
android/app/release/
android/app/debug/
*.apk
*.aab

# ── Build iOS (si ajouté un jour) ─────────────────────────────────────
ios/App/Pods/
ios/App/build/
ios/App/App.xcworkspace/

# ── Capacitor (régénéré par npx cap sync depuis www/) ─────────────────
android/app/src/main/assets/public/
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json

# ── OS / éditeur ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
*.log

# Google Services (e.g. APIs or Firebase)
google-services.json

# Android Profiling
*.hprof

# IntelliJ
misc.xml
deploymentTargetDropDown.xml
render.experimental.xml

# Android Studio generated files and folders
captures/
.externalNativeBuild/
.cxx/
output.json