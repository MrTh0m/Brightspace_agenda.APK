{
  "appId": "io.github.mrth0m.brightspaceagenda",
  "appName": "Brightspace Agenda",
  "webDir": "www",
  "bundledWebRuntime": false,
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "SplashScreen": {
      "launchShowDuration": 1200,
      "backgroundColor": "#1c1b18",
      "showSpinner": false
    }
  },
  "android": {
    "allowMixedContent": false
  }
}